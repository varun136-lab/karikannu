{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "karikannu",
	"main": "src/index.js",
	"compatibility_date": "2026-07-02",
	"observability": {
		"enabled": true
	},
	"assets": {
		"directory": "site",
		"binding": "ASSETS",
		"run_worker_first": true
	},
	"compatibility_flags": ["nodejs_compat"],
	"workers_dev": false,
	"routes": [
		{ "pattern": "karikannu.com", "custom_domain": true },
		{ "pattern": "www.karikannu.com", "custom_domain": true }
	]
}
